# ===== TAURUS MEDICAL — NGINX =====
# Домен: kliniki-izrailya.solomatin-marketing.ru
# Статика: /var/www/taurus/extracted
# tables API: 127.0.0.1:8788   publish-server: 127.0.0.1:8787
#
# Файл: /etc/nginx/sites-available/taurus
# Активация: ln -s /etc/nginx/sites-available/taurus /etc/nginx/sites-enabled/
#
# ВАЖНО про относительные пути:
# Фронт обращается к API относительно текущей страницы:
#   - со страниц в корне:        tables/...        -> /tables/...
#   - со страниц в подпапках:    ../tables/...     -> /tables/...  (т.к. ../ из /napravleniya/ = /)
# Поэтому достаточно одного location /tables/.

server {
    listen 80;
    server_name kliniki-izrailya.solomatin-marketing.ru;

    root /var/www/taurus/extracted;
    index index.html;

    # ---- tables API ----
    location /tables/ {
        proxy_pass http://127.0.0.1:8788;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ---- publish-server (auth + публикация SEO-страниц из админки) ----
    location /admin/ {
        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ---- статика сайта ----
    location / {
        try_files $uri $uri/ =404;
    }

    # Кэш для ассетов
    location ~* \.(css|js|jpg|jpeg|png|gif|ico|svg|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public";
        try_files $uri =404;
    }

    # 404
    error_page 404 /404.html;

    # Не отдавать БД и серверные файлы
    location ~ ^/(server|.*\.db|.*\.db-wal|.*\.db-shm)(/|$) {
        deny all;
        return 404;
    }
}

# После выпуска SSL через certbot этот блок будет дополнен автоматически
# (certbot --nginx -d kliniki-izrailya.solomatin-marketing.ru)
